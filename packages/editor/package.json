{
  "name": "@fsdx/editor",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./editor.css": "./dist/editor.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "rslib --watch",
    "build": "rslib build",
    "postbuild": "node -e \"require('fs').cpSync('src/editor.css','dist/editor.css')\"",
    "test": "rstest",
    "test:watch": "rstest --watch"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-bubble-menu": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-list": "^3.27.1",
    "@tiptap/extension-subscript": "^3.27.1",
    "@tiptap/extension-superscript": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-typography": "^3.27.1",
    "@tiptap/extensions": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1"
  },
  "devDependencies": {
    "@rslib/core": "^0.23.0",
    "@rstest/adapter-rslib": "^0.10.5",
    "@rstest/core": "^0.10.5",
    "happy-dom": "^20.10.3",
    "typescript": "^6.0.3"
  }
}
